---
const baseUrl = import.meta.env.BASE_URL;
const docsLink = baseUrl + 'docs/introduction';
---

<nav id="navbar" class="fixed top-0 inset-x-0 z-50 transition-all duration-500">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href={baseUrl} class="font-serif text-lg font-semibold tracking-tight text-aria-ink">Aria</a>

    <div class="hidden md:flex items-center gap-7 text-[0.8rem] font-medium text-aria-ink-muted">
      <a href={baseUrl} class="hover:text-aria-ink transition-colors">首页</a>
      <a href={docsLink} class="hover:text-aria-ink transition-colors">文档</a>
      <a href="https://github.com/17Artist/Aria" target="_blank" rel="noopener" class="hover:text-aria-ink transition-colors flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    <button id="mobile-menu-btn" class="md:hidden p-2 -mr-2 text-aria-ink-muted" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden px-6 pb-4 space-y-2 text-sm text-aria-ink-secondary bg-white/90 backdrop-blur-lg">
    <a href={baseUrl} class="block py-2">首页</a>
    <a href={docsLink} class="block py-2">文档</a>
    <a href="https://github.com/17Artist/Aria" target="_blank" class="block py-2">GitHub</a>
  </div>
</nav>

<script>
  const nb = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 30) {
      nb?.classList.add('bg-white/80', 'backdrop-blur-xl', 'shadow-[0_1px_0_rgba(0,0,0,0.04)]');
    } else {
      nb?.classList.remove('bg-white/80', 'backdrop-blur-xl', 'shadow-[0_1px_0_rgba(0,0,0,0.04)]');
    }
  });
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
