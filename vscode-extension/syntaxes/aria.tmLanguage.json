{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Aria",
    "scopeName": "source.aria",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#storage" },
        { "include": "#annotations" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#classes" },
        { "include": "#constants" },
        { "include": "#variables" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.aria",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.documentation.aria",
                    "begin": "/\\*\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.block.aria",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.triple.aria",
                    "begin": "\"\"\"",
                    "end": "\"\"\"",
                    "patterns": [
                        { "include": "#string-interpolation" },
                        { "include": "#string-escape" }
                    ]
                },
                {
                    "name": "string.quoted.single.aria",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        { "include": "#string-interpolation" },
                        { "include": "#string-escape" }
                    ]
                },
                {
                    "name": "string.quoted.double.aria",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "include": "#string-interpolation" },
                        { "include": "#string-escape" }
                    ]
                }
            ]
        },
        "string-interpolation": {
            "name": "meta.interpolation.aria",
            "begin": "\\{",
            "end": "\\}",
            "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.aria" } },
            "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.aria" } },
            "patterns": [
                { "include": "source.aria" }
            ]
        },
        "string-escape": {
            "name": "constant.character.escape.aria",
            "match": "\\\\[ntrb\\\\'\"]"
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.aria",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.aria",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.aria",
                    "match": "\\b0[oO][0-7]+\\b"
                },
                {
                    "name": "constant.numeric.float.aria",
                    "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.aria",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.aria",
                    "match": "\\b(if|elif|else|while|for|in|switch|match|case|break|return|next|async|try|catch|finally|throw|import|from|as|export)\\b"
                },
                {
                    "name": "keyword.other.aria",
                    "match": "\\b(class|extends|new|super)\\b"
                }
            ]
        },
        "storage": {
            "patterns": [
                {
                    "name": "storage.type.aria",
                    "match": "\\b(var|val|global|server|client)(?=\\.)"
                },
                {
                    "name": "variable.language.aria",
                    "match": "\\b(self|args|none)\\b"
                }
            ]
        },
        "annotations": {
            "name": "meta.annotation.aria",
            "match": "@[a-zA-Z_\\u4e00-\\u9fa5][a-zA-Z0-9_\\u4e00-\\u9fa5]*",
            "captures": {
                "0": { "name": "storage.type.annotation.aria" }
            }
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.aria",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.spread.aria",
                    "match": "\\.\\.\\."
                },
                {
                    "name": "keyword.operator.optional-chain.aria",
                    "match": "\\?\\."
                },
                {
                    "name": "keyword.operator.nullish.aria",
                    "match": "\\?\\?"
                },
                {
                    "name": "keyword.operator.comparison.aria",
                    "match": "~~|==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.assignment.aria",
                    "match": "~=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|>>>="
                },
                {
                    "name": "keyword.operator.logical.aria",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.arithmetic.aria",
                    "match": "\\+\\+|--|\\+|-|\\*|/|%"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.aria",
                    "match": "\\b([a-zA-Z_\\u4e00-\\u9fa5][a-zA-Z0-9_\\u4e00-\\u9fa5]*)(?=\\s*\\()"
                },
                {
                    "comment": "Namespace function call: math.sin, fs.read, etc.",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\.)",
                    "captures": {
                        "1": { "name": "entity.name.namespace.aria" },
                        "2": { "name": "punctuation.accessor.aria" }
                    }
                }
            ]
        },
        "classes": {
            "patterns": [
                {
                    "match": "\\b(class)\\s+([A-Z][a-zA-Z0-9_\\u4e00-\\u9fa5]*)",
                    "captures": {
                        "1": { "name": "keyword.other.aria" },
                        "2": { "name": "entity.name.class.aria" }
                    }
                },
                {
                    "match": "\\b(extends)\\s+([A-Z][a-zA-Z0-9_\\u4e00-\\u9fa5]*)",
                    "captures": {
                        "1": { "name": "keyword.other.aria" },
                        "2": { "name": "entity.other.inherited-class.aria" }
                    }
                },
                {
                    "match": "\\b(new)\\s+([A-Z][a-zA-Z0-9_\\u4e00-\\u9fa5]*)",
                    "captures": {
                        "1": { "name": "keyword.other.aria" },
                        "2": { "name": "entity.name.class.aria" }
                    }
                }
            ]
        },
        "constants": {
            "name": "constant.language.aria",
            "match": "\\b(true|false|none)\\b"
        },
        "variables": {
            "patterns": [
                {
                    "comment": "Dot-prefix variable: var.x, val.y, global.z",
                    "match": "\\b(var|val|global|server|client)\\.(\\w+)",
                    "captures": {
                        "1": { "name": "storage.type.aria" },
                        "2": { "name": "variable.other.aria" }
                    }
                }
            ]
        }
    }
}
